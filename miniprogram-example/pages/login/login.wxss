/* pages/login/login.wxss - 登录页面样式 */

.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #0f766e 0%, #1aa38f 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.logo-section {
  margin-top: 100rpx;
  text-align: center;
}

.logo {
  width: 200rpx;
  height: 200rpx;
  border-radius: 40rpx;
  background: white;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.login-section {
  margin-top: 120rpx;
  width: 100%;
  max-width: 600rpx;
}

.wechat-login-btn {
  width: 100%;
  height: 100rpx;
  background: white;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  font-size: 32rpx;
  color: #0f766e;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.wechat-icon {
  width: 48rpx;
  height: 48rpx;
}

.tips {
  margin-top: 60rpx;
  padding: 40rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 24rpx;
  backdrop-filter: blur(10rpx);
}

.tip-text {
  display: block;
  font-size: 28rpx;
  color: white;
  margin-bottom: 30rpx;
  text-align: center;
}

.feature-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.feature-item {
  font-size: 26rpx;
  color: white;
  padding-left: 20rpx;
}
